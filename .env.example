# ─── Frontend Configuration ────────────────────────────────────────────────────

# Backend API URL
# In development: Leave empty to use Next.js rewrites (/api/* -> http://localhost:5000/api/*).
# In production: required. Set to your hosted backend URL (e.g., https://api.srmnexus.app).
NEXT_PUBLIC_API_URL=

# Analytics and monitoring (optional)
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_APP_ENV=production

# Feature flags (optional)
# NEXT_PUBLIC_ENABLE_BETA_FEATURES=false
